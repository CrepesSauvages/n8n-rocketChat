{
  "name": "n8n-nodes-rocketchat-extended",
  "version": "0.1.0",
  "description": "n8n community node for extended Rocket.Chat operations (channels, messages, threads, reactions, and more)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "rocketchat",
    "rocket.chat",
    "chat",
    "channels",
    "messages"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "babou"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "dist/nodes/RocketChatExtended/RocketChatExtended.node.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RocketChatExtendedApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RocketChatExtended/RocketChatExtended.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
