{
  "name": "@crepessauvages/n8n-nodes-rocketchat-extended",
  "version": "0.3.6",
  "description": "n8n community node for extended Rocket.Chat operations (channels, messages, threads, reactions, and more)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "rocketchat",
    "rocket.chat",
    "chat",
    "channels",
    "messages"
  ],
  "license": "MIT",
  "homepage": "https://github.com/CrepesSauvages/n8n-rocketChat#readme",
  "author": {
    "name": "CrepesSauvages"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CrepesSauvages/n8n-rocketChat.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RocketChatExtendedApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RocketChatExtended/RocketChatExtended.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "gulp": "^5.0.1",
    "jest": "^30.2.0",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
